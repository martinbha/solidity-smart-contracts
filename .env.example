# Copy to .env and fill in. Everything is optional for local development —
# with no .env the utils scripts target a local Anvil node with Anvil's
# built-in account #0.

# RPC endpoint (e.g. an Alchemy/Infura URL for a testnet)
# RPC_URL=http://127.0.0.1:8545

# Deployer key — this account becomes the Billboard owner and upgrade admin.
# NEVER commit a real key; .env is gitignored.
# PRIVATE_KEY=0x...

# Initial message for the Billboard deploy
# INITIAL_MESSAGE=gm, world
